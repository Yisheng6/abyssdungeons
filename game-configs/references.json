    "skillTypes": ["active", "passive", "ultimate"],
    "elements": ["none", "fire", "water", "earth", "wind", "light", "dark"],
    "itemQualities": ["common", "fine", "rare", "epic", "legendary", "mythic"],
    "itemSlots": ["weapon", "helmet", "armor", "legs", "boots", "necklace", "ring1", "ring2"],
    "monsterTypes": ["normal", "elite", "boss"],
    "aiTypes": ["aggressive", "defensive", "cunning", "support", "berserk"],
    "roomTypes": ["normal", "elite", "treasure", "trap", "safe", "merchant", "boss", "hidden", "altar"],
    "consumableTargets": ["self", "enemy", "ally", "all_enemies", "all_allies"],
    "chatChannels": ["world", "area", "party", "guild"],
    "leaderboardCategories": ["deepest_layer", "speedrun", "kills", "wealth", "gear_score"],
    "statusEffects": ["poison", "burn", "freeze", "stun", "bleed", "buff_atk", "buff_def", "buff_agi"]
  },

  "crossReferences": {
    "skills.classId": { "$ref": "enums.classIds" },
    "enemies.aiType": { "$ref": "enums.aiTypes" },
