  },

  "namingRules": {
    "idFormat": "lowercase_snake_case",
    "idPattern": "^[a-z][a-z0-9_]*$",
    "maxIdLength": 32,
    "nameMaxLength": 20,
    "descriptionMaxLength": 500
  }
}
